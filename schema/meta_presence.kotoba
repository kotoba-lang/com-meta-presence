// Meta_presence clean-room schema -> Datomic EAVT mapping
// Generated by deepen_actors.py (ADR 260607 deepening phase).

namespace meta_presence {

    entity Anchor {
        id: string @unique
        sceneId: string
        x: float
        y: float
        z: float
        persistent: boolean
        createdAt: datetime
        updatedAt: datetime
    }

    entity Scene {
        id: string @unique
        name: string
        deviceId: string
        meshRef: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity Mesh {
        id: string @unique
        sceneId: string
        vertexCount: integer
        contentRef: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity Session {
        id: string @unique
        deviceId: string
        appId: string
        startedAt: datetime
        createdAt: datetime
        updatedAt: datetime
    }

    entity Asset {
        id: string @unique
        sceneId: string
        type: string
        contentRef: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity Device {
        id: string @unique
        model: string
        platform: string
        trackingMode: string
        createdAt: datetime
        updatedAt: datetime
    }

}

    // Auto-injected Cognitive Schema
    entity CognitiveRecord {
        id: string @unique
        originalPayload: string
        aiStatus: string
        aiInsights: json
        computedAt: datetime
    }
